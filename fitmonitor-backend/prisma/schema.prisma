generator client {
  provider        = "prisma-client-js"
  engineType      = "client"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

enum WorkoutStatus {
  PLANNED
  ACTIVE
  COMPLETED
  CANCELED
}

enum Difficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

model User {
  id             Int             @id @default(autoincrement())
  name           String
  email          String          @unique
  passwordHash   String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  activeWorkouts ActiveWorkout[]
  progressStats  ProgressStats?
  progressHistory ProgressHistory[]
  goals          Goal[]
  dietEntries    DietEntry[]
  calendarEvents CalendarEvent[]
  healthMetrics  HealthMetric[]
}

model WorkoutType {
  id             Int             @id @default(autoincrement())
  name           String          @unique
  description    String?
  image          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  trainings      Training[]
  activeWorkouts ActiveWorkout[]
}

model Training {
  id              Int                @id @default(autoincrement())
  title           String
  description     String
  image           String?
  badge           String?
  durationMinutes Int
  calories        Int
  difficulty      Difficulty          @default(BEGINNER)
  typeId          Int
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  type            WorkoutType         @relation(fields: [typeId], references: [id], onDelete: Restrict)
  trainingExercises TrainingExercise[]
  activeWorkouts ActiveWorkout[]

  @@index([typeId])
}

model Exercise {
  id          Int                @id @default(autoincrement())
  title       String
  description String
  muscle      String
  difficulty  Difficulty         @default(BEGINNER)
  equipment   String?
  image       String?
  steps       String[]
  mistakes    String[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  trainingExercises TrainingExercise[]
}

model TrainingExercise {
  id          Int       @id @default(autoincrement())
  trainingId  Int
  exerciseId  Int
  order       Int       @default(1)
  sets        Int?
  reps        String?
  restSeconds Int?

  training    Training  @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  exercise    Exercise  @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@unique([trainingId, exerciseId])
  @@index([exerciseId])
}

model ActiveWorkout {
  id              Int            @id @default(autoincrement())
  userId          Int
  trainingId      Int?
  typeId          Int
  title           String
  status          WorkoutStatus  @default(ACTIVE)
  startedAt       DateTime       @default(now())
  finishedAt      DateTime?
  durationMinutes Int?
  caloriesBurned  Int?
  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  training        Training?      @relation(fields: [trainingId], references: [id], onDelete: SetNull)
  type            WorkoutType    @relation(fields: [typeId], references: [id], onDelete: Restrict)

  @@index([userId, status])
  @@index([typeId])
  @@index([trainingId])
}

model ProgressStats {
  id              Int       @id @default(autoincrement())
  userId          Int       @unique
  workouts        Int       @default(0)
  calories        Int       @default(0)
  activeMinutes   Int       @default(0)
  steps           Int       @default(0)
  streak          Int       @default(0)
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ProgressHistory {
  id              Int       @id @default(autoincrement())
  userId          Int
  activeWorkoutId Int?
  title           String
  typeName        String
  durationMinutes Int
  calories        Int
  date            DateTime  @default(now())
  image           String?
  createdAt       DateTime  @default(now())

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

model Achievement {
  id          Int       @id @default(autoincrement())
  title       String
  description String
  points      Int       @default(0)
  icon        String
  isUnlocked  Boolean   @default(false)
  unlockedDate DateTime?
  current     Int       @default(0)
  target      Int
  unit        String
  createdAt   DateTime  @default(now())
}

model Goal {
  id          Int       @id @default(autoincrement())
  userId      Int?
  type        String
  title       String
  description String
  current     Float     @default(0)
  target      Float
  unit        String
  deadline    DateTime?
  status      String    @default("active")
  image       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model CalendarEvent {
  id        Int       @id @default(autoincrement())
  userId    Int?
  date      DateTime
  title     String
  duration  String?
  status    String    @default("planned")
  createdAt DateTime  @default(now())

  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

model Recipe {
  id          Int       @id @default(autoincrement())
  title       String
  image       String?
  time        String
  calories    Int
  protein     Float
  fat         Float
  carbs       Float
  description String
  category    String
  createdAt   DateTime  @default(now())
}

model MealPlan {
  id          Int       @id @default(autoincrement())
  title       String
  badge       String
  image       String?
  description String
  calories    String
  protein     String
  fat         String
  carbs       String
  schedule    Json      @default("[]")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model DietEntry {
  id        Int       @id @default(autoincrement())
  userId    Int?
  name      String
  mealType  String?
  calories  Float
  protein   Float     @default(0)
  fat       Float     @default(0)
  carbs     Float     @default(0)
  addedAt   DateTime  @default(now())

  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, addedAt])
}

model HealthMetric {
  id        Int       @id @default(autoincrement())
  userId    Int?
  name      String
  value     String
  trend     String?
  trendText String?
  measuredAt DateTime @default(now())

  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, measuredAt])
}
